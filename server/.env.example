# Server Port
PORT=5000

# MongoDB URI (Atlas or Local)
MONGODB_URI=mongodb://localhost:27017/nutrition-assistant

# JWT Secrets
JWT_SECRET=super_secret_jwt_access_token_key_123!
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_key_456!
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Gemini API Key (for Chatbot)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Credentials (Optional - Local storage fallback is active)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Node Environment
NODE_ENV=development
